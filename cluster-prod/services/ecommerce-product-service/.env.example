# Spring Boot imports this file via:
# spring.config.import=optional:file:.env[.properties]

# Server
server.port=8082

# PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5433/productdb
spring.datasource.username=admin
spring.datasource.password=password

# Elasticsearch
spring.elasticsearch.uris=http://localhost:9200

# OAuth2 / Keycloak
spring.security.oauth2.resourceserver.jwt.issuer-uri=http://localhost:8180/realms/ecommerce
spring.keycloak.resource=ecommerce-backend
spring.keycloak.credentials.secret=CHANGE_ME

# MinIO
minio.url=http://localhost:9000
minio.access-key=minioadmin
minio.secret-key=minioadmin
minio.bucket-name=ecommerce-products
