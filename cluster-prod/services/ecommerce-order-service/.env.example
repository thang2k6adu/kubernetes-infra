SERVER_PORT=8081
SERVER_CONTEXT_PATH=/

USER_DB_NAME=user_db
USER_DB_USERNAME=admin
USER_DB_PASSWORD=password
USER_DB_PORT=5433
DB_URL=jdbc:postgresql://localhost:5433/user_db
DB_USERNAME=admin
DB_PASSWORD=password

JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HTTP_PORT=8180
KEYCLOAK_SERVER_URL=http://localhost:8180
KEYCLOAK_REALM=ecommerce
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_ID=ecommerce-backend
KEYCLOAK_CLIENT_SECRET=replace_with_real_secret
JWT_ISSUER_URI=http://localhost:8180/realms/ecommerce
JWT_JWK_SET_URI=http://localhost:8180/realms/ecommerce/protocol/openid-connect/certs
SECURITY_KEYCLOAK_CLIENT_ID=ecommerce-backend

KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=admin
KEYCLOAK_DB_PASSWORD=password
KEYCLOAK_DB_PORT=5440

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
USER_REGISTERED_TOPIC=user.registered
KAFKA_SECURITY_PROTOCOL=PLAINTEXT # Change to SASL_SSL if using authentication
KAFKA_SASL_MECHANISM=SCRAM-SHA-512 # Change to SCRAM-SHA-512 if using secure authentication
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Profiles (optional)
SPRING_PROFILES_ACTIVE=kafka-sasl